# Environment: local | cloud
ENVIRONMENT=local

# Database
DATABASE_URL=postgresql+asyncpg://finance:finance@localhost:5432/finance

# TrueLayer (get from https://console.truelayer.com)
TRUELAYER_CLIENT_ID=your_client_id
TRUELAYER_CLIENT_SECRET=your_client_secret
TRUELAYER_REDIRECT_URI=http://localhost:8080/api/v1/auth/truelayer/callback
TRUELAYER_WEBHOOK_SECRET=your_webhook_secret

# Use TrueLayer sandbox (true for dev, false for prod)
TRUELAYER_SANDBOX=true

# Token encryption key — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_key

# API authentication key for all endpoints
API_KEY=your_api_key
